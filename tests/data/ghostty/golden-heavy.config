# Generated by 'make ghostty-golden' — DO NOT EDIT.
config-file = themes/nord
font-family = Iosevka
font-family = Hack
font-size = 14
font-feature = +liga
font-feature = ss01
cursor-style = bar
background-blur = 30
palette = 0=000000
palette = 1=ff0000
bell-features = audio,+attention
keybind = ctrl+a=reset
keybind = ctrl+b>c=close_tab
env = 
env = FOO=bar
background-image-position = top-left
some-future-key = future-value

# extra-content (overrides above)
# user override
font-thicken = true
