#!/bin/sh

abs_top_srcdir="`cd "@abs_top_srcdir@" > /dev/null; pwd`"
abs_top_builddir="`cd "@abs_top_builddir@" > /dev/null; pwd`"

# Cross-channel dependency: many modules import (asahi guix ...).
# Developers who have a local checkout of the asahi-guix channel can
# point at it via R0MAN_EXTRA_LOAD_PATH (colon-separated list of dirs
# containing additional Guile source modules).  Example:
#   R0MAN_EXTRA_LOAD_PATH=/path/to/asahi-guix/channel ./pre-inst-env make
GUILE_LOAD_COMPILED_PATH="$abs_top_builddir/modules${GUILE_LOAD_COMPILED_PATH:+:}$GUILE_LOAD_COMPILED_PATH"
GUILE_LOAD_PATH="$abs_top_builddir/modules:$abs_top_srcdir/modules:$abs_top_srcdir${R0MAN_EXTRA_LOAD_PATH:+:}$R0MAN_EXTRA_LOAD_PATH${GUILE_LOAD_PATH:+:}$GUILE_LOAD_PATH"
export GUILE_LOAD_COMPILED_PATH GUILE_LOAD_PATH

GUIX_PACKAGE_PATH="$abs_top_srcdir/modules${R0MAN_EXTRA_LOAD_PATH:+:}$R0MAN_EXTRA_LOAD_PATH${GUIX_PACKAGE_PATH:+:}$GUIX_PACKAGE_PATH"
export GUIX_PACKAGE_PATH

PATH="$abs_top_builddir/scripts:$PATH"
export PATH

exec "$@"
